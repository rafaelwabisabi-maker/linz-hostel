ysrgb%26w%3D1600&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F5883096%2Fpexels-photo-5883096.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F5883096%2Fpexels-photo-5883096.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F5883096%2Fpexels-photo-5883096.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=3840&amp;q=75\"/></div><div style=\"max-width:1280px;margin:0 auto;position:relative;z-index:10;display:grid;grid-template-columns:1fr 1fr;gap:88px;align-items:center\"><div><div style=\"display:flex;align-items:center;gap:12px;margin-bottom:24px\"><div style=\"width:32px;height:1px;background:#C4997E\"></div><span style=\"color:#C4997E;font-size:10px;letter-spacing:0.3em;text-transform:uppercase\">The Problem</span></div><h2 style=\"font-family:var(--font-heading);font-size:clamp(44px, 5.5vw, 76px);color:#C8BCB4;font-weight:700;line-height:1.02;margin:0 0 32px\">1 million visitors.<br/>Zero connection.</h2><p style=\"color:rgba(200,188,180,0.75);font-size:17px;line-height:1.82;margin:0\">Austria ranks #49 out of 53 countries for social friendliness. Linz draws over 700,000 festival visitors every year — yet most leave without a single real conversation. Existing accommodation doesn&#x27;t bridge the gap between visitor and community. We do.</p></div><div style=\"background:rgba(255,255,255,0.04);border:1px solid rgba(196,153,126,0.18);padding:48px\"><p style=\"font-family:var(--font-heading);font-size:21px;color:#C8BCB4;font-style:italic;line-height:1.65;margin:0 0 32px\">“I&#x27;ve been living in Linz for three months. I still don&#x27;t know a single person outside of work.”</p><div style=\"width:36px;height:1px;background:#C4997E;margin-bottom:14px\"></div><p style=\"color:#C4997E;font-size:11px;letter-spacing:0.18em;text-transform:uppercase;margin:0\">The voice that started this project.</p></div></div></section><section style=\"background:#f7f4f0;overflow:hidden\"><div style=\"display:grid;grid-template-columns:1fr 1fr\"><div style=\"position:relative;min-height:560px\"><img alt=\"Teachcation model\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F6611262%2Fpexels-photo-6611262.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F6611262%2Fpexels-photo-6611262.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F6611262%2Fpexels-photo-6611262.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F6611262%2Fpexels-photo-6611262.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F6611262%2Fpexels-photo-6611262.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F6611262%2Fpexels-photo-6611262.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F6611262%2Fpexels-photo-6611262.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F6611262%2Fpexels-photo-6611262.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F6611262%2Fpexels-photo-6611262.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=3840&amp;q=75\"/><div style=\"position:absolute;inset:0;background:rgba(74,69,67,0.1)\"></div></div><div style=\"padding:88px 64px 88px 72px;display:flex;flex-direction:column;justify-content:center\"><div style=\"display:flex;align-items:center;gap:12px;margin-bottom:18px\"><div style=\"width:32px;height:1px;background:#C4997E\"></div><span style=\"color:#C4997E;font-size:10px;letter-spacing:0.3em;text-transform:uppercase\">Our Secret Sauce</span></div><h2 style=\"font-family:var(--font-heading);font-size:clamp(32px, 3.5vw, 48px);color:#4A4543;font-weight:700;margin:0 0 20px;line-height:1.1\">Teachcation —<br/>come to learn.</h2><p style=\"color:#6b6460;font-size:16px;line-height:1.78;margin:0 0 36px\">We coined the term. Tourists who want more than sightseeing book a Teachcation: a curated stay that includes access to Linz&#x27;s creative ecosystem — maker spaces, fab labs, coding workshops, ceramics studios, design sprints. You leave with a skill and a community.</p><div style=\"display:grid;grid-template-columns:1fr 1fr;gap:24px\"><div style=\"border-left:2px solid #C4997E;padding-left:16px\"><div style=\"color:#6b6460;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:4px\">Typical stay</div><div style=\"font-family:var(--font-heading);font-size:24px;color:#4A4543;font-weight:700\">4–7 nights</div></div><div style=\"border-left:2px solid #C4997E;padding-left:16px\"><div style=\"color:#6b6460;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:4px\">ADR premium</div><div style=\"font-family:var(--font-heading);font-size:24px;color:#4A4543;font-weight:700\">+22%</div></div><div style=\"border-left:2px solid #C4997E;padding-left:16px\"><div style=\"color:#6b6460;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:4px\">Return rate</div><div style=\"font-family:var(--font-heading);font-size:24px;color:#4A4543;font-weight:700\">High</div></div><div style=\"border-left:2px solid #C4997E;padding-left:16px\"><div style=\"color:#6b6460;font-size:12px;letter-spacing:0.1em;text-transform:uppercase;margin-bottom:4px\">CAC</div><div style=\"font-family:var(--font-heading);font-size:24px;color:#4A4543;font-weight:700\">Near zero</div></div></div></div></div></section><section style=\"background:#ffffff;padding:100px 48px\"><div style=\"max-width:1280px;margin:0 auto;display:grid;grid-template-columns:1fr 1fr;gap:88px;align-items:center\"><div style=\"position:relative;padding-bottom:36px\"><div style=\"position:relative;height:520px\"><img alt=\"Social impact\" loading=\"lazy\" decoding=\"async\" data-nimg=\"fill\" style=\"position:absolute;height:100%;width:100%;left:0;top:0;right:0;bottom:0;object-fit:cover;color:transparent\" sizes=\"100vw\" srcSet=\"/_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F5638820%2Fpexels-photo-5638820.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=640&amp;q=75 640w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F5638820%2Fpexels-photo-5638820.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=750&amp;q=75 750w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F5638820%2Fpexels-photo-5638820.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=828&amp;q=75 828w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F5638820%2Fpexels-photo-5638820.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=1080&amp;q=75 1080w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F5638820%2Fpexels-photo-5638820.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=1200&amp;q=75 1200w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F5638820%2Fpexels-photo-5638820.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=1920&amp;q=75 1920w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F5638820%2Fpexels-photo-5638820.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=2048&amp;q=75 2048w, /_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F5638820%2Fpexels-photo-5638820.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=3840&amp;q=75 3840w\" src=\"/_next/image?url=https%3A%2F%2Fimages.pexels.com%2Fphotos%2F5638820%2Fpexels-photo-5638820.jpeg%3Fauto%3Dcompress%26cs%3Dtinysrgb%26w%3D1600&amp;w=3840&amp;q=75\"/></div><div style=\"position:absolute;bottom:0;right:-36px;background:#4A4543;padding:32px 36px\"><div style=\"font-family:var(--font-heading);color:#C4997E;font-size:42px;font-weight:700;line-height:1\">€1 = €4.50</div><div style=\"color:rgba(200,188,180,0.6);font-size:11px;letter-spacing:0.14em;text-transform:uppercase;margin-top:6px\">Social Return on Investment</div></div></div><div><div style=\"display:flex;align-items:center;gap:12px;margin-bottom:18px\"><div style=\"width:32px;height:1px;background:#C4997E\"></div><span style=\"color:#C4997E;font-size:10px;letter-spacing:0.3em;text-transform:uppercase\">Hospitality for Good</span></div><h2 style=\"font-family:var(--font-heading);font-size:clamp(30px, 3.2vw, 44px);color:#4A4543;font-weight:700;margin:0 0 16px;line-height:1.15\">Profit and purpose<br/>on the same balance sheet.</h2><p style=\"color:#6b6460;font-size:16px;line-height:1.78;margin:0 0 48px\">The social mission isn&#x27;t charity — it&#x27;s strategy. Long-term social rentals create a revenue floor. The community they build becomes our marketing. Lower CAC. Higher retention. Better press.</p><div style=\"display:grid;grid-template-columns:1fr 1fr;gap:28px\"><div style=\"border-left:2px solid #C4997E;padding-left:18px\"><div style=\"font-family:var(--font-heading);font-size:26px;color:#4A4543;font-weight:700;margin-bottom:6px\">1:4.5</div><div style=\"color:#6b6460;font-size:13px;line-height:1.5\">SROI — every €1 returns €4.50 social value</div></div><div style=\"border-left:2px solid #C4997E;padding-left:18px\"><div style=\"font-family:var(--font-heading);font-size:26px;color:#4A4543;font-weight:700;margin-bottom:6px\">18 beds</div><div style=\"color:#6b6460;font-size:13px;line-height:1.5\">Permanently reserved for social r